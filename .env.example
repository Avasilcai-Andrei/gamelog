# Frontend (Vite) — point at the backend host/IP
# Example: VITE_API_URL=http://192.168.1.10:4000
VITE_API_URL=http://localhost:4000
# Optional explicit WS URL; otherwise it's derived from VITE_API_URL.
# VITE_WS_URL=ws://192.168.1.10:4000/ws

VITE_RAWG_KEY=

# Backend
# PORT=4000
# HOST=0.0.0.0
DATABASE_URL=postgresql://user:password@host/dbname
# CERT_KEY=./certs/server.key
# CERT_CRT=./certs/server.crt
# JWT_SECRET=change-this-to-a-long-random-string
# JWT_EXPIRES_IN=1h

# Frontend — inactivity logout timeout in milliseconds (default 30 minutes)
# VITE_INACTIVITY_MS=1800000

# Google OAuth (create credentials at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Email / SMTP (for password reset and email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend origin used in email links (change to LAN IP for lab demo)
CLIENT_URL=http://localhost:5173
